{% extends "base.jinja" %}

{% block content %}
<section class="section section-top">
    <div class="shell detail-layout">
        <div>
            <a href="{{ url('portfolio') }}" class="btn-link"><i class="fa-solid fa-arrow-left"></i> Portfolyoya dön</a>
            <div class="eyebrow" style="margin-top:24px;">{{ item.industry or 'Kurumsal Proje' }}</div>
            <h1 class="headline">{{ item.title }}</h1>
            <p class="lead" style="margin-top:20px;">{{ item.description }}</p>
            <div class="tag-list" style="margin-top:24px;">
                {% if item.client_name %}<span class="tag">{{ item.client_name }}</span>{% endif %}
                {% if item.location %}<span class="tag">{{ item.location }}</span>{% endif %}
                {% if item.delivery_year %}<span class="tag">{{ item.delivery_year }}</span>{% endif %}
                {% if item.highlight_metric %}<span class="tag">{{ item.highlight_metric }}</span>{% endif %}
            </div>
        </div>

        <aside class="card" style="position:sticky; top:110px;">
            <div class="eyebrow">Proje Özeti</div>
            <div style="display:grid; gap:14px; margin-top:18px;">
                <div>
                    <div class="kicker">Kapsam</div>
                    <strong>{{ item.scope_summary or 'Özel yazılım geliştirme' }}</strong>
                </div>
                <div>
                    <div class="kicker">Durum</div>
                    <strong>{% if item.is_live %}Canlı{% else %}Teslim edildi{% endif %}</strong>
                </div>
                {% if item.project_url %}
                <a href="{{ item.project_url }}" target="_blank" rel="noopener" class="btn-secondary">Projeyi Aç</a>
                {% endif %}
                <a href="{{ url('contact') }}" class="btn-primary">Benzer Çözüm İstiyorum</a>
            </div>
        </aside>
    </div>
</section>

<section class="section-tight">
    <div class="shell grid-3">
        <article class="card">
            <div class="eyebrow">Zorluk</div>
            <p class="lead" style="margin-top:16px;">{{ item.challenge or item.description }}</p>
        </article>
        <article class="card">
            <div class="eyebrow">Çözüm</div>
            <p class="lead" style="margin-top:16px;">{{ item.solution or item.description }}</p>
        </article>
        <article class="card">
            <div class="eyebrow">Sonuç</div>
            <p class="lead" style="margin-top:16px;">{{ item.results or item.highlight_metric or 'Süreç görünürlüğü ve daha hızlı operasyon akışı sağlandı.' }}</p>
        </article>
    </div>
</section>

{% if item.get_technology_list() %}
<section class="section-tight">
    <div class="shell">
        <div class="eyebrow">Teknoloji Seti</div>
        <ul class="stack-list" style="margin-top:18px;">
            {% for technology in item.get_technology_list() %}
            <li class="stack-item">{{ technology }}</li>
            {% endfor %}
        </ul>
    </div>
</section>
{% endif %}

{% if project_references %}
<section class="section-tight">
    <div class="shell">
        <div class="eyebrow">Müşteri Yorumu</div>
        <div class="grid-2" style="margin-top:20px;">
            {% for reference in project_references %}
            <article class="card">
                <p class="lead" style="font-size:1rem; margin:0;">“{{ reference.quote }}”</p>
                <div style="margin-top:18px;">
                    <strong>{{ reference.person_name }}</strong>
                    <div class="kicker">{{ reference.role }} · {{ reference.company_name }}</div>
                </div>
            </article>
            {% endfor %}
        </div>
    </div>
</section>
{% endif %}

<section class="section">
    <div class="shell">
        <div class="two-col" style="align-items:end; margin-bottom:28px;">
            <div>
                <div class="eyebrow">Diğer Projeler</div>
                <h2 class="section-title">Benzer kurumsal ihtiyaçlara verdiğimiz diğer teknik yanıtlar.</h2>
            </div>
            <a href="{{ url('portfolio') }}" class="btn-link">Tümünü gör <i class="fa-solid fa-arrow-right"></i></a>
        </div>
        <div class="grid-3">
            {% for related in related_items %}
            <article class="card">
                <div class="eyebrow">{{ related.industry or 'Kurumsal Proje' }}</div>
                <h3 class="subheadline" style="font-size:1.35rem; margin-top:16px;">{{ related.title }}</h3>
                <p class="lead" style="font-size:.95rem; margin-top:14px;">{{ related.description }}</p>
                <a href="{{ related.get_absolute_url() }}" class="btn-link" style="margin-top:18px;">İncele <i class="fa-solid fa-arrow-right"></i></a>
            </article>
            {% endfor %}
        </div>
    </div>
</section>
{% endblock %}