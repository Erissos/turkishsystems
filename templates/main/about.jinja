{% extends "base.jinja" %}

{% block content %}
<section class="section section-top">
    <div class="shell two-col" style="align-items:end;">
        <div>
            <div class="eyebrow">Kurumsal</div>
            <h1 class="headline">Mühendislik disipliniyle çalışan, markayı korurken operasyonu <em>hızlandıran</em> bir teknik partner.</h1>
        </div>
        <p class="lead" style="margin:0;">TurkishSystems, kurumsal web yapısı ile portal ve operasyon sistemlerini tek standarda taşıyarak kurumların müşterileriyle daha net, hızlı ve kontrollü çalışmasını sağlar.</p>
    </div>
</section>

<section class="section-tight">
    <div class="shell grid-4">
        {% for stat in stats %}
        <article class="card">
            <p class="stat-value">{{ stat.value }}</p>
            <p class="stat-label">{{ stat.label }}</p>
        </article>
        {% endfor %}
    </div>
</section>

<section class="section">
    <div class="shell two-col">
        <article class="card">
            <div class="eyebrow">Yaklaşım</div>
            <h2 class="section-title">Kurumsal güven, süreç görünürlüğü ve sürdürülebilir yazılım <em>aynı mimaride</em> buluşur.</h2>
            <p class="lead" style="margin-top:14px;">Her projede önce işleyişi ve takip boşluklarını analiz ederiz. Sonra bu ihtiyacı marka ile uyumlu ekranlara, yönetici görünürlüğüne ve güvenli veri akışına çeviririz.</p>
        </article>
        <article class="card">
            <div class="eyebrow">Çalışma Prensipleri</div>
            <ul class="clean-list" style="display:grid; gap:14px; margin-top:20px;">
                <li class="kicker"><i class="fa-solid fa-check gold"></i> Net kapsam, net teslim ve net takip</li>
                <li class="kicker"><i class="fa-solid fa-check gold"></i> Dosya ve süreç akışını görünür kılan portal tasarımı</li>
                <li class="kicker"><i class="fa-solid fa-check gold"></i> Güvenlik, rol yönetimi ve denetim izi odaklı mimari</li>
                <li class="kicker"><i class="fa-solid fa-check gold"></i> Canlıya alma sonrası da devam eden teknik partnerlik</li>
            </ul>
        </article>
    </div>
</section>

<section class="section-tight">
    <div class="shell">
        <div class="two-col" style="align-items:end; margin-bottom:28px;">
            <div>
                <div class="eyebrow">Referans Güveni</div>
                <h2 class="section-title">Kurumsal görünüm kadar, operasyonel etkiyi de görünür kılan projeler teslim ediyoruz.</h2>
            </div>
        </div>
        <div class="grid-3">
            {% for reference in references %}
            <article class="card">
                <p class="lead" style="font-size:1rem; margin:0;">“{{ reference.quote }}”</p>
                <div style="margin-top:18px;">
                    <strong>{{ reference.person_name }}</strong>
                    <div class="kicker">{{ reference.role }} · {{ reference.company_name }}</div>
                    <div class="tag-list" style="margin-top:12px;">
                        <span class="tag">{{ reference.sector }}</span>
                        <span class="tag">{{ reference.outcome }}</span>
                    </div>
                </div>
            </article>
            {% endfor %}
        </div>
    </div>
</section>

<section class="section">
    <div class="shell panel" style="padding:34px;">
        <div class="two-col" style="align-items:center;">
            <div>
                <div class="eyebrow">Birlikte Çalışalım</div>
                <h2 class="section-title">Kurumsal sitenizi, müşteri portalınızı ve takip katmanınızı <em>aynı standarda</em> taşıyalım.</h2>
            </div>
            <div class="btn-row" style="justify-content:flex-end;">
                <a href="{{ url('contact') }}" class="btn-primary">Talep Gönder</a>
                <a href="{{ portal_url }}" target="_blank" rel="noopener" class="btn-secondary">Portal</a>
            </div>
        </div>
    </div>
</section>
{% endblock %}