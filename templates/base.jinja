<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ site.meta_title }}</title>
    {% if site.meta_description %}
    <meta name="description" content="{{ site.meta_description }}">
    {% endif %}
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,600;0,700;0,900;1,700&family=DM+Sans:wght@300;400;500;700&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
    <style>
        :root {
            --canvas: #0d0b09;
            --canvas-2: #131110;
            --canvas-3: #1a1714;
            --ink: #f0e8d6;
            --ink-2: #c8bfb0;
            --ink-3: #6e6458;
            --gold: #c09a45;
            --gold-lt: #debb72;
            --gold-dk: #6b5322;
            --rule: rgba(192,154,69,.15);
            --rule-lt: rgba(240,232,214,.06);
            --success: #8ab57b;
            --danger: #cc7a6f;
            --shadow: 0 30px 90px rgba(0, 0, 0, .32);
            --radius-lg: 0;
            --radius-md: 0;
            --radius-sm: 0;
        }

        * { box-sizing: border-box; }
        html { scroll-behavior: smooth; }

        body {
            margin: 0;
            color: var(--ink);
            background:
                radial-gradient(circle at top right, rgba(192,154,69,.11), transparent 24%),
                radial-gradient(circle at left 20%, rgba(240,232,214,.05), transparent 18%),
                linear-gradient(180deg, #0d0b09 0%, #0f0c09 45%, #0d0b09 100%);
            font-family: 'DM Sans', sans-serif;
            line-height: 1.7;
        }

        body::before {
            content: '';
            position: fixed;
            inset: 0;
            pointer-events: none;
            opacity: .05;
            background-image: linear-gradient(rgba(255,255,255,.03) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.03) 1px, transparent 1px);
            background-size: 80px 80px;
            mask-image: radial-gradient(circle at center, black 45%, transparent 92%);
        }

        a { color: inherit; }
        .shell { max-width: 1280px; margin: 0 auto; padding: 0 28px; }
        .section { padding: 112px 0; position: relative; }
        .section-tight { padding: 80px 0; position: relative; }
        .section-top { padding-top: 100px; }
        .eyebrow {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            color: var(--gold-lt);
            text-transform: uppercase;
            font-family: 'DM Mono', monospace;
            font-size: 11px;
            letter-spacing: .28em;
        }
        .eyebrow::before {
            content: '';
            width: 36px;
            height: 1px;
            background: linear-gradient(90deg, var(--gold), transparent);
        }
        .headline {
            margin: 18px 0 0;
            font-family: 'Playfair Display', serif;
            font-size: clamp(2.4rem, 5vw, 5.1rem);
            line-height: 1.04;
            font-weight: 900;
            letter-spacing: -.03em;
        }
        .headline em,
        .subheadline em,
        .section-title em { color: var(--gold); font-style: italic; }
        .subheadline {
            margin: 0;
            font-family: 'Playfair Display', serif;
            font-size: clamp(2rem, 3.5vw, 3.4rem);
            line-height: 1.1;
            font-weight: 700;
        }
        .section-title {
            margin: 14px 0 0;
            font-family: 'Playfair Display', serif;
            font-size: clamp(1.8rem, 3vw, 2.8rem);
            line-height: 1.15;
            font-weight: 700;
        }
        .lead {
            color: var(--ink-2);
            font-size: 1.02rem;
            max-width: 720px;
        }
        .muted { color: var(--ink-3); }
        .gold { color: var(--gold); }
        .panel,
        .card,
        .metric,
        .form-shell {
            background: linear-gradient(180deg, rgba(26,23,20,.95), rgba(19,17,16,.96));
            border: 1px solid var(--rule);
            border-radius: var(--radius-md);
            box-shadow: var(--shadow);
        }
        .card {
            padding: 28px;
            transition: border-color .15s ease, background .15s ease;
        }
        .card:hover {
            border-color: var(--gold);
            background: linear-gradient(180deg, rgba(30,26,22,.98), rgba(19,17,16,.98));
        }
        .btn-row { display: flex; flex-wrap: wrap; gap: 14px; }
        .btn-primary,
        .btn-secondary,
        .btn-link {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            min-height: 48px;
            padding: 0 22px;
            border-radius: 0;
            text-decoration: none;
            font-family: 'DM Mono', monospace;
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: .18em;
            transition: border-color .15s ease, background .15s ease, color .15s ease;
            cursor: pointer;
        }
        .btn-primary {
            background: linear-gradient(135deg, var(--gold) 0%, var(--gold-lt) 100%);
            color: var(--canvas);
            border: none;
        }
        .btn-primary:hover { background: linear-gradient(135deg, var(--gold-lt) 0%, var(--gold) 100%); }
        .btn-secondary {
            border: 1px solid rgba(222,187,114,.25);
            background: rgba(255,255,255,.01);
            color: var(--ink);
        }
        .btn-secondary:hover,
        .btn-link:hover {
            border-color: var(--gold);
            background: rgba(192,154,69,.10);
        }
        .btn-link {
            padding: 0;
            min-height: auto;
            border: none;
            color: var(--gold-lt);
            justify-content: flex-start;
        }
        .site-header {
            position: sticky;
            top: 0;
            z-index: 100;
            backdrop-filter: blur(18px);
            background: rgba(13,11,9,.82);
            border-bottom: 1px solid var(--rule);
        }
        .header-row {
            min-height: 82px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 20px;
        }
        .wordmark {
            display: inline-flex;
            align-items: center;
            gap: 0;
            text-decoration: none;
            font-family: 'Playfair Display', serif;
            font-size: 1.18rem;
            font-weight: 700;
            letter-spacing: .03em;
        }
        .wordmark em { color: var(--gold); font-style: italic; }
        .desktop-nav {
            display: flex;
            align-items: center;
            gap: 22px;
        }
        .nav-link {
            text-decoration: none;
            color: var(--ink-2);
            font-family: 'DM Mono', monospace;
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: .18em;
        }
        .nav-link:hover { color: var(--gold-lt); }
        .header-actions { display: flex; align-items: center; gap: 12px; }
        .mobile-toggle {
            display: none;
            width: 46px;
            height: 46px;
            border-radius: 0;
            border: 1px solid var(--rule);
            background: rgba(255,255,255,.02);
            color: var(--ink);
            align-items: center;
            justify-content: center;
        }
        .mobile-nav { display: none; padding: 0 0 20px; }
        .mobile-nav.open { display: block; }
        .mobile-nav-inner {
            display: grid;
            gap: 12px;
            padding: 18px;
            border-radius: 0;
            border: 1px solid var(--rule);
            background: rgba(19,17,16,.96);
        }
        .hero-grid,
        .two-col,
        .portfolio-hero,
        .detail-layout,
        .auth-grid,
        .contact-grid,
        .dashboard-grid,
        .footer-grid {
            display: grid;
            gap: 28px;
        }
        .hero-grid { grid-template-columns: 1.15fr .85fr; align-items: stretch; }
        .two-col,
        .portfolio-hero,
        .contact-grid,
        .auth-grid,
        .dashboard-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
        .detail-layout { grid-template-columns: minmax(0, 1.15fr) 360px; align-items: start; }
        .footer-grid { grid-template-columns: 1.6fr .9fr .9fr; }
        .grid-2,
        .grid-3,
        .grid-4 {
            display: grid;
            gap: 20px;
        }
        .grid-2 { grid-template-columns: repeat(2, minmax(0, 1fr)); }
        .grid-3 { grid-template-columns: repeat(3, minmax(0, 1fr)); }
        .grid-4 { grid-template-columns: repeat(4, minmax(0, 1fr)); }
        .hero-panel {
            padding: 34px;
            overflow: hidden;
            position: relative;
        }
        .hero-panel::before,
        .hero-panel::after {
            content: '';
            position: absolute;
            border-radius: 0;
            border: 1px solid rgba(222,187,114,.12);
        }
        .hero-panel::before { width: 320px; height: 320px; right: -120px; top: -120px; transform: rotate(45deg); }
        .hero-panel::after { width: 180px; height: 180px; left: -60px; bottom: -60px; transform: rotate(45deg); }
        .stat-block {
            padding: 24px;
            border-radius: var(--radius-sm);
            border: 1px solid var(--rule-lt);
            background: rgba(255,255,255,.01);
        }
        .stat-value {
            margin: 0 0 8px;
            font-family: 'Playfair Display', serif;
            font-size: 2.2rem;
            line-height: 1;
            color: var(--gold);
            font-weight: 900;
        }
        .stat-label { margin: 0; color: var(--ink-2); font-size: .86rem; }
        .tag-list,
        .stack-list,
        .clean-list {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            padding: 0;
            margin: 0;
            list-style: none;
        }
        .tag,
        .stack-item {
            padding: 9px 12px;
            border-radius: 0;
            border: 1px solid var(--rule);
            background: rgba(255,255,255,.02);
            color: var(--ink-2);
            font-size: .82rem;
        }
        .stack-item { font-family: 'DM Mono', monospace; font-size: .72rem; letter-spacing: .08em; text-transform: uppercase; }
        .alert {
            padding: 16px 18px;
            border-radius: var(--radius-sm);
            border: 1px solid var(--rule);
            margin-bottom: 18px;
        }
        .alert.success { border-color: rgba(138,181,123,.4); background: rgba(138,181,123,.08); }
        .alert.error { border-color: rgba(204,122,111,.4); background: rgba(204,122,111,.08); }
        .alert.info { background: rgba(192,154,69,.08); }
        label {
            display: block;
            margin-bottom: 8px;
            color: var(--ink-2);
            font-size: .85rem;
        }
        input,
        select,
        textarea {
            width: 100%;
            border-radius: 0;
            border: 1px solid var(--rule);
            background: rgba(0,0,0,.16);
            color: var(--ink);
            padding: 14px 16px;
            font-family: 'DM Sans', sans-serif;
            font-size: .95rem;
        }
        input:focus,
        select:focus,
        textarea:focus {
            outline: none;
            border-color: var(--gold);
            box-shadow: none;
        }
        .field-error { margin-top: 6px; color: #f1ae9f; font-size: .78rem; }
        .checkbox-row { display: flex; align-items: center; gap: 12px; }
        .checkbox-row input { width: 18px; height: 18px; margin: 0; }
        .kicker { color: var(--ink-3); font-size: .84rem; }

        .row-item {
            display: grid;
            grid-template-columns: 56px 1fr;
            gap: 0 28px;
            padding: 32px 0;
            border-bottom: 1px solid var(--rule);
        }
        .row-item:last-child { border-bottom: none; }
        .row-number {
            font-family: 'DM Mono', monospace;
            font-size: 13px;
            color: var(--gold);
            letter-spacing: .08em;
            padding-top: 4px;
        }
        .row-body h3 { margin: 0 0 10px; }
        .row-body p { margin: 0; }

        .product-hero-card {
            display: grid;
            grid-template-columns: 1fr auto;
            align-items: start;
            gap: 28px;
            padding: 36px;
            background: linear-gradient(180deg, rgba(26,23,20,.95), rgba(19,17,16,.96));
            border: 1px solid var(--rule);
            transition: border-color .15s ease;
        }
        .product-hero-card:hover { border-color: var(--gold); }
        .product-hero-card + .product-hero-card { margin-top: 20px; }

        .divider {
            width: 100%;
            height: 1px;
            background: var(--rule);
            margin: 0;
            border: none;
        }

        .metric { padding: 22px; }
        .metric-title { margin: 0 0 8px; color: var(--ink-2); font-size: .9rem; }
        .metric-value { margin: 0; font-size: 1.45rem; font-family: 'Playfair Display', serif; font-weight: 700; }
        .footer {
            border-top: 1px solid var(--rule);
            background: rgba(19,17,16,.88);
            padding: 42px 0 26px;
            margin-top: 60px;
        }
        .inline-form { display: inline; }

        @media (max-width: 1120px) {
            .desktop-nav,
            .header-actions .nav-auth-inline,
            .header-actions .nav-primary-inline { display: none; }
            .mobile-toggle { display: inline-flex; }
            .hero-grid,
            .two-col,
            .portfolio-hero,
            .contact-grid,
            .auth-grid,
            .dashboard-grid,
            .detail-layout,
            .footer-grid,
            .grid-4,
            .grid-3,
            .grid-2 { grid-template-columns: 1fr; }
            .product-hero-card { grid-template-columns: 1fr; }
            .row-item { grid-template-columns: 40px 1fr; gap: 0 18px; }
        }

        @media (max-width: 720px) {
            .shell { padding: 0 18px; }
            .section { padding: 78px 0; }
            .section-tight { padding: 58px 0; }
            .section-top { padding-top: 88px; }
            .hero-panel,
            .card,
            .form-shell { padding: 22px; }
            .btn-primary,
            .btn-secondary { width: 100%; }
            .btn-row { flex-direction: column; }
        }
    </style>
</head>
<body>
    <header class="site-header">
        <div class="shell header-row">
            <a href="{{ url('home') }}" class="wordmark">{{ site.brand_name }}<em>{{ site.brand_highlight }}</em></a>
            <nav class="desktop-nav">
                {% for link in nav_links %}
                    {% if not link.is_primary %}
                    <a href="{{ link.url }}" class="nav-link">{{ link.label }}</a>
                    {% endif %}
                {% endfor %}
            </nav>
            <div class="header-actions">
                <a href="{{ portal_url }}" target="_blank" rel="noopener" class="btn-secondary nav-primary-inline">Portal</a>
                {% if request.user.is_authenticated %}
                <a href="{{ url('dashboard') }}" class="btn-secondary nav-auth-inline">Hesabım</a>
                <form action="{{ url('logout') }}" method="post" class="inline-form nav-auth-inline">
                    {{ csrf_input }}
                    <button type="submit" class="btn-primary">Çıkış</button>
                </form>
                {% else %}
                <a href="{{ url('account_auth') }}" class="btn-secondary nav-auth-inline">Kayıt / Giriş</a>
                {% endif %}
                {% for link in nav_links %}
                    {% if link.is_primary %}
                    <a href="{{ link.url }}" class="btn-primary nav-primary-inline">{{ link.label }}</a>
                    {% endif %}
                {% endfor %}
                <button type="button" class="mobile-toggle" id="mobile-toggle" aria-label="Menüyü aç">
                    <i class="fa-solid fa-bars"></i>
                </button>
            </div>
        </div>
        <div class="shell mobile-nav" id="mobile-nav">
            <div class="mobile-nav-inner">
                {% for link in nav_links %}
                <a href="{{ link.url }}" class="nav-link">{{ link.label }}</a>
                {% endfor %}
                <a href="{{ portal_url }}" target="_blank" rel="noopener" class="btn-secondary">Portal</a>
                {% if request.user.is_authenticated %}
                <a href="{{ url('dashboard') }}" class="btn-secondary">Hesabım</a>
                <form action="{{ url('logout') }}" method="post">
                    {{ csrf_input }}
                    <button type="submit" class="btn-primary">Çıkış</button>
                </form>
                {% else %}
                <a href="{{ url('account_auth') }}" class="btn-secondary">Kayıt / Giriş</a>
                {% endif %}
            </div>
        </div>
    </header>

    <main>
        <div class="shell" style="padding-top:12px;">
            {% if messages %}
                {% for message in messages %}
                <div class="alert {% if message.tags == 'success' %}success{% elif message.tags == 'error' %}error{% else %}info{% endif %}">{{ message }}</div>
                {% endfor %}
            {% endif %}
        </div>
        {% block content %}{% endblock %}
    </main>

    <footer class="footer">
        <div class="shell footer-grid">
            <div>
                <div class="wordmark" style="margin-bottom:16px;">{{ site.brand_name }}<em>{{ site.brand_highlight }}</em></div>
                <p class="lead" style="margin:0 0 18px; max-width: 460px;">{{ site.footer_intro }}</p>
                <div class="tag-list">
                    <span class="tag">Kurumsal web</span>
                    <span class="tag">Müşteri portalı</span>
                    <span class="tag">Takip sistemleri</span>
                    <span class="tag">Entegrasyon</span>
                </div>
            </div>
            <div>
                <div class="eyebrow">Navigasyon</div>
                <div style="display:grid; gap:12px; margin-top:18px;">
                    {% for link in nav_links %}
                    <a href="{{ link.url }}" class="kicker" style="text-decoration:none;">{{ link.label }}</a>
                    {% endfor %}
                    <a href="{{ portal_url }}" target="_blank" rel="noopener" class="kicker" style="text-decoration:none;">Portal</a>
                </div>
            </div>
            <div>
                <div class="eyebrow">İletişim</div>
                <div style="display:grid; gap:12px; margin-top:18px;">
                    {% if site.contact_email %}
                    <a href="mailto:{{ site.contact_email }}" class="kicker" style="text-decoration:none;">{{ site.contact_email }}</a>
                    {% endif %}
                    {% if site.contact_whatsapp_url %}
                    <a href="{{ site.contact_whatsapp_url }}" target="_blank" rel="noopener" class="kicker" style="text-decoration:none;">WhatsApp</a>
                    {% endif %}
                    {% for link in social_links %}
                    <a href="{{ link.url }}" target="_blank" rel="noopener" class="kicker" style="text-decoration:none;">{{ link.label }}</a>
                    {% endfor %}
                </div>
            </div>
        </div>
        <div class="shell" style="margin-top:30px; padding-top:18px; border-top:1px solid var(--rule); display:flex; justify-content:space-between; gap:16px; flex-wrap:wrap;">
            <span class="kicker">{{ site.footer_copyright }}</span>
            <span class="kicker">Portal senkroni, belge akışı ve takip görünürlüğü odaklı sistemler</span>
        </div>
    </footer>

    <script>
        const mobileToggle = document.getElementById('mobile-toggle');
        const mobileNav = document.getElementById('mobile-nav');
        mobileToggle?.addEventListener('click', () => {
            mobileNav.classList.toggle('open');
        });
    </script>
    {% block extra_scripts %}{% endblock %}
</body>
</html>