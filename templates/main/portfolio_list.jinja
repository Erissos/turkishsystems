{% extends "base.jinja" %}

{% block content %}
<section class="section section-top">
    <div class="shell portfolio-hero" style="align-items:end;">
        <div>
            <div class="eyebrow">Portfolyo</div>
            <h1 class="headline">Portfolyo alanında önce <em>iş ortaklarının logoları</em> görünür.</h1>
        </div>
        <p class="lead" style="margin:0;">Admin panelden logo yüklendiğinde burada görünür. İlgili öğede bağlantı girildiyse tıklanır, bağlantı yoksa sadece görünür kalır.</p>
    </div>
</section>

<section class="section-tight">
    <div class="shell grid-4">
        {% for item in portfolio_items %}
            {% if item.project_url %}
            <a href="{{ item.project_url }}" target="_blank" rel="noopener" class="card" style="display:flex; align-items:center; justify-content:center; min-height:150px; text-decoration:none; text-align:center;">
                {% if item.image_url %}
                <img src="{{ item.image_url }}" alt="{{ item.title }}" style="max-width:170px; max-height:64px; width:auto; height:auto; object-fit:contain; filter:grayscale(1) contrast(1.1);">
                {% else %}
                <strong>{{ item.title }}</strong>
                {% endif %}
            </a>
            {% else %}
            <article class="card" style="display:flex; align-items:center; justify-content:center; min-height:150px; text-align:center; cursor:default;">
                {% if item.image_url %}
                <img src="{{ item.image_url }}" alt="{{ item.title }}" style="max-width:170px; max-height:64px; width:auto; height:auto; object-fit:contain; filter:grayscale(1) contrast(1.1);">
                {% else %}
                <strong>{{ item.title }}</strong>
                {% endif %}
            </article>
            {% endif %}
        {% endfor %}
    </div>
</section>
{% endblock %}