{% extends "base.jinja" %}

{% block content %}
<section class="section section-top">
    <div class="shell detail-layout">
        <div>
            <a href="{{ url('products') }}" class="btn-link"><i class="fa-solid fa-arrow-left"></i> Ürünlere dön</a>
            <div class="eyebrow" style="margin-top:24px;">Ürün Detayı</div>
            <h1 class="headline">{{ product.name }}</h1>
            <p class="lead" style="margin-top:20px;">{{ product.short_description }}</p>
            <ul class="clean-list" style="display:grid; gap:10px; margin-top:24px;">
                {% for feature in product.get_detailed_features_list() %}
                <li class="kicker"><i class="fa-solid fa-check gold"></i> {{ feature }}</li>
                {% endfor %}
            </ul>
        </div>

        <aside class="card" style="position:sticky; top:110px;">
            <div class="eyebrow">Hızlı Aksiyon</div>
            <p class="lead" style="font-size:.95rem; margin-top:16px;">Bu ürün için paket ve kapsam talebinizi bırakın. Gerekirse satış modelini veya teknik kapsamı sizin için netleştirelim.</p>
            <div class="btn-row" style="margin-top:18px;">
                <a href="{{ portal_url }}" target="_blank" rel="noopener" class="btn-secondary">Portal</a>
                <a href="{{ url('contact') }}" class="btn-primary">Genel Talep Formu</a>
            </div>
        </aside>
    </div>
</section>

<section class="section-tight">
    <div class="shell grid-3">
        {% for package in packages %}
        <article class="card" style="{% if package.is_highlighted %}border-color: rgba(222,187,114,.4);{% endif %}">
            <div class="eyebrow">{{ package.name }}</div>
            <h2 class="subheadline" style="font-size:1.6rem; margin-top:16px;">{{ package.price }}</h2>
            <p class="lead" style="font-size:.95rem; margin-top:14px;">{{ package.description }}</p>
            <ul class="clean-list" style="display:grid; gap:10px; margin-top:18px;">
                {% for feature in package.get_features_list() %}
                <li class="kicker"><i class="fa-solid fa-check gold"></i> {{ feature }}</li>
                {% endfor %}
            </ul>
        </article>
        {% endfor %}
    </div>
</section>

<section class="section-tight">
    <div class="shell two-col">
        <div>
            <div class="eyebrow">Müşteri Geri Bildirimi</div>
            <div style="display:grid; gap:18px; margin-top:18px;">
                {% for review in reviews %}
                <article class="card">
                    <p class="lead" style="font-size:1rem; margin:0;">“{{ review.comment }}”</p>
                    <div style="margin-top:18px;">
                        <strong>{{ review.full_name }}</strong>
                        <div class="kicker">{{ review.role }}</div>
                    </div>
                </article>
                {% endfor %}
            </div>
        </div>
        <div>
            <div class="eyebrow">Sık Sorulanlar</div>
            <div style="display:grid; gap:18px; margin-top:18px;">
                {% for faq in faqs %}
                <article class="card">
                    <strong>{{ faq.question }}</strong>
                    <p class="lead" style="font-size:.95rem; margin-top:12px;">{{ faq.answer }}</p>
                </article>
                {% endfor %}
            </div>
        </div>
    </div>
</section>

<section class="section">
    <div class="shell form-shell" style="padding:34px; max-width:960px;">
        <div class="eyebrow">Paket Talebi</div>
        <h2 class="section-title">Bu ürün için paket ve kapsam talebinizi bırakın.</h2>
        <p class="lead" style="margin-top:14px;">Paket seçiminizle birlikte özel notlarınızı ve beklentinizi iletebilirsiniz.</p>

        {% if order_error %}
        <div class="alert error" style="margin-top:20px;">{{ order_error }}</div>
        {% endif %}

        <form method="post" style="margin-top:22px; display:grid; gap:18px;">
            {{ csrf_input }}
            <div class="grid-2">
                <div>
                    <label for="full_name">Ad Soyad</label>
                    <input id="full_name" type="text" name="full_name" value="{{ order_form.full_name }}" required>
                </div>
                <div>
                    <label for="email">E-posta</label>
                    <input id="email" type="email" name="email" value="{{ order_form.email }}" required>
                </div>
            </div>
            <div class="grid-2">
                <div>
                    <label for="phone">Telefon</label>
                    <input id="phone" type="text" name="phone" value="{{ order_form.phone }}">
                </div>
                <div>
                    <label for="package_id">Paket</label>
                    <select id="package_id" name="package_id" required>
                        <option value="">Paket seçin</option>
                        {% for package in packages %}
                        <option value="{{ package.id }}" data-ask-details="{{ 1 if package.ask_details_on_order else 0 }}" {% if order_form.package_id == (package.id ~ '') %}selected{% endif %}>{{ package.name }} · {{ package.price }}</option>
                        {% endfor %}
                    </select>
                </div>
            </div>
            <div id="detail-note-wrap" style="display:none;">
                <label for="detail_note">Özel Kapsam Notu</label>
                <textarea id="detail_note" name="detail_note" rows="5">{{ order_form.detail_note }}</textarea>
            </div>
            <button type="submit" class="btn-primary">Paket Talebi Gönder</button>
        </form>
    </div>
</section>
{% endblock %}

{% block extra_scripts %}
<script>
    const packageSelect = document.getElementById('package_id');
    const detailWrap = document.getElementById('detail-note-wrap');
    const detailNote = document.getElementById('detail_note');

    function syncDetailNoteField() {
        if (!packageSelect) return;
        const selectedOption = packageSelect.options[packageSelect.selectedIndex];
        const needsDetails = selectedOption && selectedOption.dataset.askDetails === '1';
        detailWrap.style.display = needsDetails ? 'block' : 'none';
        if (detailNote) {
            detailNote.required = needsDetails;
        }
    }

    packageSelect?.addEventListener('change', syncDetailNoteField);
    syncDetailNoteField();
</script>
{% endblock %}