{% extends "base.jinja" %}

{% block content %}
<section class="section section-top">
    <div class="shell" style="max-width:960px;">
        <div class="eyebrow">Ürünlerimiz</div>
        <h1 class="headline" style="margin-bottom:20px;">Sattığımız <em>ürünler</em></h1>
        <p class="lead">Hizmet değil, paket. Danışmanlık, yazılım ürünü ve teknik üretim tarafında somut teklifler.</p>
    </div>
</section>

<section class="section-tight">
    <div class="shell" style="max-width:960px;">
        {% for product in products %}
        <div class="product-hero-card">
            <div>
                <div class="eyebrow">{{ '%02d' % loop.index }}</div>
                <h2 class="subheadline" style="font-size:1.6rem; margin-top:12px;">{{ product.name }}</h2>
                <p class="lead" style="font-size:.95rem; margin-top:10px; max-width:560px;">{{ product.short_description }}</p>
                <div style="display:flex; flex-wrap:wrap; gap:8px; margin-top:16px;">
                    {% for feature in product.get_detailed_features_list()[:3] %}
                    <span class="tag">{{ feature }}</span>
                    {% endfor %}
                </div>
            </div>
            <a href="{{ product.get_absolute_url() }}" class="btn-primary" style="white-space:nowrap; align-self:center;">Detay <i class="fa-solid fa-arrow-right"></i></a>
        </div>
        {% endfor %}
    </div>
</section>

<hr class="divider" style="max-width:960px; margin:0 auto;">

<section class="section-tight">
    <div class="shell" style="max-width:960px;">
        <div class="eyebrow">Portal</div>
        <p class="lead" style="margin-top:12px; max-width:640px;">{{ portal_summary.body }}</p>
        <a href="{{ portal_url }}" target="_blank" rel="noopener" class="btn-link" style="margin-top:14px;">Portalı incele <i class="fa-solid fa-arrow-right"></i></a>
    </div>
</section>
{% endblock %}