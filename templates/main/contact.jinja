{% extends "base.jinja" %}

{% block content %}
<section class="section section-top">
    <div class="shell contact-grid" style="align-items:end;">
        <div>
            <div class="eyebrow">Talep ve İletişim</div>
            <h1 class="headline">Kayıt olun, talep gönderin ve kurumsal ihtiyaçlarınızı bizimle <em>planlı biçimde</em> ilerletin.</h1>
        </div>
        <p class="lead" style="margin:0;">Bu form; portal, dosya paylaşımı, takip sistemi, kurumsal web veya entegrasyon ihtiyacınızı kapsamlı şekilde iletmeniz için hazırlandı.</p>
    </div>
</section>

<section class="section-tight">
    <div class="shell contact-grid">
        <div class="form-shell" style="padding:34px;">
            <div class="eyebrow">Talep Formu</div>
            <h2 class="section-title">Projeyi kısa değil, doğru anlatın.</h2>
            <p class="lead" style="margin-top:14px;">Portal erişimi, dosya paylaşımı ve takip ihtiyacınız varsa formda mutlaka belirtin.</p>

            {% if request_errors %}
            <div class="alert error" style="margin-top:20px;">Formda eksik veya hatalı alanlar var. Lütfen alanları kontrol edin.</div>
            {% endif %}

            <form method="post" style="display:grid; gap:18px; margin-top:22px;">
                {{ csrf_input }}
                <div class="grid-2">
                    <div>
                        <label for="full_name">Ad Soyad</label>
                        <input id="full_name" name="full_name" type="text" value="{{ request_values.full_name }}">
                        {% if 'full_name' in request_errors %}<div class="field-error">{{ request_errors['full_name'][0] }}</div>{% endif %}
                    </div>
                    <div>
                        <label for="email">E-posta</label>
                        <input id="email" name="email" type="email" value="{{ request_values.email }}">
                        {% if 'email' in request_errors %}<div class="field-error">{{ request_errors['email'][0] }}</div>{% endif %}
                    </div>
                </div>

                <div class="grid-2">
                    <div>
                        <label for="company_name">Şirket</label>
                        <input id="company_name" name="company_name" type="text" value="{{ request_values.company_name }}">
                    </div>
                    <div>
                        <label for="phone">Telefon</label>
                        <input id="phone" name="phone" type="text" value="{{ request_values.phone }}">
                    </div>
                </div>

                <div class="grid-3">
                    <div>
                        <label for="request_type">Talep Türü</label>
                        <select id="request_type" name="request_type">
                            <option value="">Seçin</option>
                            {% for value, label in request_type_choices %}
                            <option value="{{ value }}" {% if request_values.request_type == value %}selected{% endif %}>{{ label }}</option>
                            {% endfor %}
                        </select>
                        {% if 'request_type' in request_errors %}<div class="field-error">{{ request_errors['request_type'][0] }}</div>{% endif %}
                    </div>
                    <div>
                        <label for="budget_range">Bütçe</label>
                        <select id="budget_range" name="budget_range">
                            <option value="">Seçin</option>
                            {% for value, label in budget_choices %}
                            <option value="{{ value }}" {% if request_values.budget_range == value %}selected{% endif %}>{{ label }}</option>
                            {% endfor %}
                        </select>
                    </div>
                    <div>
                        <label for="timeline">Zaman Planı</label>
                        <select id="timeline" name="timeline">
                            <option value="">Seçin</option>
                            {% for value, label in timeline_choices %}
                            <option value="{{ value }}" {% if request_values.timeline == value %}selected{% endif %}>{{ label }}</option>
                            {% endfor %}
                        </select>
                    </div>
                </div>

                <div>
                    <label for="project_scope">Proje Kapsamı</label>
                    <textarea id="project_scope" name="project_scope" rows="6">{{ request_values.project_scope }}</textarea>
                    {% if 'project_scope' in request_errors %}<div class="field-error">{{ request_errors['project_scope'][0] }}</div>{% endif %}
                </div>

                <div>
                    <label for="systems_note">Sistem ve Operasyon Notu</label>
                    <textarea id="systems_note" name="systems_note" rows="4">{{ request_values.systems_note }}</textarea>
                </div>

                <label class="checkbox-row">
                    <input type="checkbox" name="wants_portal_access" value="on" {% if request_values.wants_portal_access %}checked{% endif %}>
                    <span>Müşterilerimize özel portal erişimi ve takip altyapısı istiyorum.</span>
                </label>

                <button type="submit" class="btn-primary">Talebi Gönder</button>
            </form>
        </div>

        <div style="display:grid; gap:18px;">
            <article class="card">
                <div class="eyebrow">Çalışma Akışı</div>
                <ol class="clean-list" style="display:grid; gap:14px; margin-top:18px;">
                    <li class="kicker"><span class="gold">1.</span> Talebiniz teknik açıdan incelenir.</li>
                    <li class="kicker"><span class="gold">2.</span> Gerekli ekranlar, portal ihtiyacı ve süreç boşlukları analiz edilir.</li>
                    <li class="kicker"><span class="gold">3.</span> Size kapsam, zaman ve uygun sistem önerisi ile dönüş yapılır.</li>
                </ol>
            </article>
            <article class="card">
                <div class="eyebrow">Hızlı Kanallar</div>
                <div style="display:grid; gap:14px; margin-top:18px;">
                    {% if site.contact_email %}<a href="mailto:{{ site.contact_email }}" class="btn-secondary">{{ site.contact_email }}</a>{% endif %}
                    {% if site.contact_whatsapp_url %}<a href="{{ site.contact_whatsapp_url }}" target="_blank" rel="noopener" class="btn-secondary">WhatsApp</a>{% endif %}
                    <a href="{{ portal_url }}" target="_blank" rel="noopener" class="btn-secondary">Portal</a>
                </div>
            </article>
            <article class="card">
                <div class="eyebrow">Kayıt Avantajı</div>
                <p class="lead" style="font-size:.95rem; margin-top:16px;">Hesap oluşturan kullanıcılar ileride taleplerini ve sistem siparişlerini kendi panelinden takip edebilir.</p>
                <a href="{{ url('account_auth') }}" class="btn-link" style="margin-top:18px;">Kayıt / Giriş sayfası <i class="fa-solid fa-arrow-right"></i></a>
            </article>
        </div>
    </div>
</section>
{% endblock %}