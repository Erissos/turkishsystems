{% extends "main/base.jinja" %}

{% block content %}

<section style="padding-top:72px; background:var(--canvas-2); border-bottom:1px solid var(--rule);">
    <div class="wrap" style="padding:5rem 2.5rem 4rem;">
        <div style="display:grid; grid-template-columns:1fr 1fr; gap:5rem; align-items:end;" class="pf-header-grid">
            <div>
                <div class="label" style="margin-bottom:1.25rem;">Ürünlerimiz</div>
                <h1 class="display" style="font-size:clamp(2.5rem,5vw,4.5rem); font-weight:900; line-height:1.04;">
                    İşinize Uygun <em style="color:var(--gold); font-style:italic;">Dijital Ürünler</em>
                </h1>
            </div>
            <div>
                <div class="h-rule" style="margin-bottom:1.5rem;"></div>
                <p style="font-size:.95rem; color:var(--ink-2); line-height:1.85;">Her ürün için özel paket yapısı, detaylı özellik setleri ve siparişe hazır akış sunuyoruz.</p>
            </div>
        </div>
    </div>
    <div style="height:2px; background:linear-gradient(90deg,transparent,var(--gold-dk),transparent);"></div>
</section>

<section class="section-pad">
    <div class="wrap">
        <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:1px; background:var(--rule);" class="portfolio-grid">
            {% for product in products %}
            <a href="/urunler/{{ product.slug }}/" class="art-card" style="display:block; text-decoration:none; padding:2.5rem 2rem;">
                <div class="mono" style="font-size:.62rem; letter-spacing:.22em; color:var(--gold-dk); margin-bottom:.75rem;">ÜRÜN — 0{{ loop.index }}</div>
                <h2 class="display" style="font-size:1.4rem; font-weight:700; color:var(--ink); margin-bottom:1rem; line-height:1.3;">{{ product.name }}</h2>
                <p style="font-size:.85rem; color:var(--ink-3); line-height:1.8; margin-bottom:1.5rem;">{{ product.short_description }}</p>
                <div class="h-rule" style="margin-bottom:1.25rem;"></div>
                <span style="display:flex; align-items:center; gap:.5rem; color:var(--gold); font-family:'DM Mono',monospace; font-size:.65rem; letter-spacing:.15em; text-transform:uppercase;">
                    Paketi İncele <i class="fa-solid fa-arrow-right" style="font-size:.6rem;"></i>
                </span>
            </a>
            {% endfor %}
        </div>
    </div>
    <style> @media(max-width:900px){ .portfolio-grid { grid-template-columns:1fr !important; } } </style>
</section>

{% endblock %}
