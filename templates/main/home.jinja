{% extends "base.jinja" %}

{% block content %}
<section class="section section-top">
    <div class="shell hero-grid">
        <div>
            <div class="eyebrow">{{ site.hero_badge_year }} · {{ site.hero_badge_text }}</div>
            <h1 class="headline">{{ site.hero_heading_line_one }} <em>{{ site.hero_heading_highlight_one }}</em><br>{{ site.hero_heading_line_two }} <em>{{ site.hero_heading_highlight_two }}</em></h1>
            <p class="lead" style="margin-top:26px;">{{ site.hero_subtitle }}</p>
            <div class="btn-row" style="margin-top:30px;">
                <a href="{{ site.primary_cta_url }}" class="btn-primary">{{ site.primary_cta_label }}</a>
                <a href="{{ site.secondary_cta_url }}" class="btn-secondary">{{ site.secondary_cta_label }}</a>
                <a href="{{ portal_url }}" target="_blank" rel="noopener" class="btn-secondary">Portal</a>
            </div>
            <ul class="tag-list" style="margin-top:28px;">
                <li class="tag">Müşteri portalı senkronu</li>
                <li class="tag">Hızlı dosya paylaşımı</li>
                <li class="tag">Takip görünürlüğü</li>
                <li class="tag">Kurumsal güven standardı</li>
            </ul>
        </div>

        <div class="hero-panel panel">
            <div class="eyebrow">Operasyon Katmanı</div>
            <div class="grid-2" style="margin-top:22px;">
                {% for stat in stats %}
                <article class="stat-block">
                    <p class="stat-value">{{ stat.value }}</p>
                    <p class="stat-label">{{ stat.label }}</p>
                </article>
                {% endfor %}
            </div>
            <div class="alert info" style="margin:24px 0 0;">
                Portal sistemlerimiz ile müşterileriniz dosyalarını daha hızlı paylaşır, süreçleri daha net takip eder ve ekipleriniz aynı operasyonda senkron kalır.
            </div>
        </div>
    </div>
</section>

<section class="section-tight">
    <div class="shell">
        <div class="two-col" style="align-items:end; margin-bottom:28px;">
            <div>
                <div class="eyebrow">Neden TurkishSystems</div>
                <h2 class="section-title">Kurumsal yapıyı sadece görünür değil, aynı zamanda <em>işletilebilir</em> hale getiriyoruz.</h2>
            </div>
            <p class="lead" style="margin:0; max-width:520px;">Her sistem; müşterinizle iletişim, dosya akışı, süreç görünürlüğü ve yönetici takibi arasında net bağ kurar.</p>
        </div>
        <div class="grid-3">
            {% for item in portal_highlights %}
            <article class="card">
                <div class="eyebrow">0{{ loop.index }}</div>
                <h3 class="subheadline" style="font-size:1.55rem; margin-top:16px;">{{ item.title }}</h3>
                <p class="lead" style="font-size:.95rem; margin-top:14px;">{{ item.body }}</p>
            </article>
            {% endfor %}
        </div>
    </div>
</section>

<section class="section">
    <div class="shell" style="max-width:900px;">
        <div style="display:flex; justify-content:space-between; align-items:end; margin-bottom:28px;">
            <div>
                <div class="eyebrow">Hizmetler</div>
                <h2 class="section-title">Sağladığımız <em>kurumsal hizmetler</em></h2>
            </div>
            <a href="{{ url('services') }}" class="btn-link">Tümü <i class="fa-solid fa-arrow-right"></i></a>
        </div>
        {% for service in services %}
        <div class="row-item">
            <div class="row-number">{{ '%02d' % loop.index }}</div>
            <div class="row-body">
                <h3 class="subheadline" style="font-size:1.2rem;">{{ service.title }}</h3>
                <p class="lead" style="font-size:.88rem; margin-top:6px;">{{ service.description }}</p>
            </div>
        </div>
        {% endfor %}
    </div>
</section>

<section class="section-tight">
    <div class="shell" style="max-width:900px;">
        <div style="display:flex; justify-content:space-between; align-items:end; margin-bottom:20px;">
            <div class="eyebrow">Portal</div>
            <a href="{{ portal_url }}" target="_blank" rel="noopener" class="btn-link">Portalı aç <i class="fa-solid fa-arrow-right"></i></a>
        </div>
        <h2 class="section-title">Müşteri portalımız: belge, talep ve teslim akışını <em>tek ekranda</em> toplar.</h2>
        <div style="display:flex; flex-wrap:wrap; gap:8px; margin-top:18px;">
            <span class="tag">Belge akışı</span>
            <span class="tag">Talep takibi</span>
            <span class="tag">Yorum geçmişi</span>
            <span class="tag">Yönetici görünürlüğü</span>
        </div>
    </div>
</section>

<section class="section">
    <div class="shell" style="max-width:960px;">
        <div style="display:flex; justify-content:space-between; align-items:end; margin-bottom:28px;">
            <div>
                <div class="eyebrow">Ürünler</div>
                <h2 class="section-title">Sattığımız <em>ürünler</em></h2>
            </div>
            <a href="{{ url('products') }}" class="btn-link">Tümü <i class="fa-solid fa-arrow-right"></i></a>
        </div>
        {% for product in products %}
        <div class="product-hero-card">
            <div>
                <div class="eyebrow">{{ '%02d' % loop.index }}</div>
                <h3 class="subheadline" style="font-size:1.35rem; margin-top:8px;">{{ product.name }}</h3>
                <p class="lead" style="font-size:.88rem; margin-top:6px;">{{ product.short_description }}</p>
            </div>
            <a href="{{ product.get_absolute_url() }}" class="btn-primary" style="white-space:nowrap; align-self:center;">Detay <i class="fa-solid fa-arrow-right"></i></a>
        </div>
        {% endfor %}
    </div>
</section>

<section class="section-tight">
    <div class="shell">
        <div style="display:flex; justify-content:space-between; align-items:end; margin-bottom:28px;">
            <div>
                <div class="eyebrow">Portfolyo</div>
                <h2 class="section-title">İş ortaklarımızın <em>logoları</em></h2>
            </div>
            <a href="{{ url('portfolio') }}" class="btn-link">Tümü <i class="fa-solid fa-arrow-right"></i></a>
        </div>
        <div class="grid-4">
            {% for item in portfolio_items %}
            <div style="display:flex; align-items:center; justify-content:center; min-height:100px; border:1px solid var(--rule); text-align:center; padding:20px;">
                {% if item.image_url %}
                <img src="{{ item.image_url }}" alt="{{ item.title }}" style="max-width:140px; max-height:52px; width:auto; height:auto; object-fit:contain; filter:grayscale(1) contrast(1.1);">
                {% else %}
                <span class="kicker">{{ item.title }}</span>
                {% endif %}
            </div>
            {% endfor %}
        </div>
    </div>
</section>

<section class="section">
    <div class="shell panel" style="padding:34px;">
        <div>
            <div class="eyebrow">Kayıt ve Talep</div>
            <h2 class="section-title">Kayıt olun, talebinizi bırakın, ardından hesabınızdan süreci <em>takip edin</em>.</h2>
            <p class="lead" style="margin-top:14px;">Yeni yapıda kullanıcılar hesap açabilir, talep formu gönderebilir ve kendi süreçlerini hesap ekranından izleyebilir.</p>
        </div>
        <div class="btn-row" style="margin-top:22px; justify-content:flex-end;">
            <a href="{{ url('account_auth') }}" class="btn-secondary">Kayıt / Giriş</a>
            <a href="{{ url('contact') }}" class="btn-primary">Talep Formu</a>
        </div>
    </div>
</section>
{% endblock %}