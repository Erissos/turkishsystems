{% extends "base.jinja" %}

{% block content %}
<section class="section section-top">
    <div class="shell" style="max-width:900px;">
        <div class="eyebrow">Hizmetler</div>
        <h1 class="headline" style="margin-bottom:20px;">Sağladığımız <em>hizmetler</em></h1>
        <p class="lead">Ürün satmıyoruz, hizmet veriyoruz. Analiz, tasarım, geliştirme, entegrasyon ve operasyon desteği.</p>
    </div>
</section>

<section class="section-tight">
    <div class="shell" style="max-width:900px;">
        {% for service in services %}
        <div class="row-item">
            <div class="row-number">{{ '%02d' % loop.index }}</div>
            <div class="row-body">
                <h3 class="subheadline" style="font-size:1.35rem;">{{ service.title }}</h3>
                <p class="lead" style="font-size:.92rem; margin-top:8px;">{{ service.description }}</p>
                <div style="display:flex; gap:24px; margin-top:14px;">
                    <span class="kicker"><i class="fa-solid fa-check gold"></i> {{ service.bullet_one }}</span>
                    <span class="kicker"><i class="fa-solid fa-check gold"></i> {{ service.bullet_two }}</span>
                </div>
            </div>
        </div>
        {% endfor %}
    </div>
</section>

<section class="section">
    <div class="shell" style="max-width:900px;">
        <div class="eyebrow">Çalışma Modeli</div>
        <h2 class="section-title" style="margin-bottom:28px;">Hizmeti teslim ederken <em>süreç netliği</em> de kuruyoruz.</h2>
        <div style="display:grid; gap:0;">
            {% for step in delivery_layers %}
            <div class="row-item" style="grid-template-columns:32px 1fr;">
                <div class="row-number">{{ '%02d' % loop.index }}</div>
                <div class="row-body">
                    <p class="lead" style="font-size:.95rem;">{{ step }}</p>
                </div>
            </div>
            {% endfor %}
        </div>
    </div>
</section>
{% endblock %}