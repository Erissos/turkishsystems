{% extends "base.jinja" %}

{% block content %}
<section class="section section-top">
    <div class="shell dashboard-grid">
        <article class="panel" style="padding:34px;">
            <div class="eyebrow">Hesabım</div>
            <h1 class="section-title">{{ display_name }}, süreçlerinizi buradan takip edebilirsiniz.</h1>
            <p class="lead" style="margin-top:14px;">Talep formlarınız ve sistem bazlı sipariş kayıtlarınız tek ekranda listelenir.</p>
            <div class="btn-row" style="margin-top:24px;">
                <a href="{{ url('contact') }}" class="btn-primary">Yeni Talep</a>
                <a href="{{ portal_url }}" target="_blank" rel="noopener" class="btn-secondary">Portal</a>
            </div>
        </article>
        <article class="card">
            <div class="eyebrow">Özet</div>
            <div class="grid-2" style="margin-top:18px;">
                <div class="metric">
                    <p class="metric-title">Toplam talep</p>
                    <p class="metric-value">{{ requests_qs|length }}</p>
                </div>
                <div class="metric">
                    <p class="metric-title">Sistem siparişi</p>
                    <p class="metric-value">{{ orders_qs|length }}</p>
                </div>
            </div>
        </article>
    </div>
</section>

<section class="section-tight">
    <div class="shell dashboard-grid">
        <div>
            <div class="eyebrow">Gönderilen Talepler</div>
            <div style="display:grid; gap:18px; margin-top:18px;">
                {% for item in requests_qs %}
                <article class="card">
                    <div style="display:flex; justify-content:space-between; gap:16px; flex-wrap:wrap;">
                        <strong>{{ item.get_request_type_display() }}</strong>
                        <span class="tag">{{ item.get_status_display() }}</span>
                    </div>
                    <p class="lead" style="font-size:.95rem; margin-top:14px;">{{ item.project_scope }}</p>
                    <div class="tag-list" style="margin-top:16px;">
                        {% if item.company_name %}<span class="tag">{{ item.company_name }}</span>{% endif %}
                        {% if item.timeline %}<span class="tag">{{ item.get_timeline_display() }}</span>{% endif %}
                        {% if item.budget_range %}<span class="tag">{{ item.get_budget_range_display() }}</span>{% endif %}
                    </div>
                    <div class="kicker" style="margin-top:12px;">{{ item.created_at }}</div>
                </article>
                {% else %}
                <article class="card">
                    <p class="lead" style="margin:0;">Henüz talep göndermediniz. İlk talebinizi oluşturmak için iletişim sayfasına geçin.</p>
                </article>
                {% endfor %}
            </div>
        </div>

        <div>
            <div class="eyebrow">Sistem Siparişleri</div>
            <div style="display:grid; gap:18px; margin-top:18px;">
                {% for order in orders_qs %}
                <article class="card">
                    <strong>{{ order.product.name }}</strong>
                    <div class="kicker" style="margin-top:8px;">{{ order.package.name if order.package else 'Paket belirtilmedi' }}</div>
                    {% if order.detail_note %}<p class="lead" style="font-size:.95rem; margin-top:14px;">{{ order.detail_note }}</p>{% endif %}
                    <div class="kicker" style="margin-top:12px;">{{ order.created_at }}</div>
                </article>
                {% else %}
                <article class="card">
                    <p class="lead" style="margin:0;">Henüz sistem bazlı sipariş kaydınız yok.</p>
                </article>
                {% endfor %}
            </div>
        </div>
    </div>
</section>
{% endblock %}